# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  JSW MCMS Frontend — Vercel Environment Variables Template              ║
# ║  Set these in Vercel Dashboard → Project → Settings → Environment Vars  ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── API URL (Railway/Render backend URL) ──────────────────────────────────────
# Example: https://jsw-mcms-api.up.railway.app/api
VITE_API_URL="https://your-backend.up.railway.app/api"

# ── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_VERSION="1.0.0"



# Conneted to PostgreSQL PG Admin4
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/mcms_db?schema=public"


# Username: postgres
# Password: admin123
# Host: localhost
# Port: 5432
# Database: postgres


# PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/mcms_db?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mcms_db
DB_USER=postgres
DB_PASSWORD=your_password_here

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret