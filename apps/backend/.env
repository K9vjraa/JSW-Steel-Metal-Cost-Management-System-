# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  JSW MCMS Backend — Production Environment Variables                    ║
# ║  Copy to .env and fill in real values. Never commit .env to git.        ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Database ────────────────────────────────────────────────────-> Settings -> Database -> Connection string)
# Format DATABASE_URL: Transaction Pooler URL (typically port 6543) with ?pgbouncer=true


# ── Token TTLs ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# ── CORS Origin (Vercel production URL) ───────────────────────────────────────Get
CLIENT_ORIGIN="https://jsw-mcms.vercel.app"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="production"

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL="info"




# Conneted to PostgreSQL PG Admin4
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/mcms_db?schema=public"


# Username: postgres
# Password: admin123
# Host: localhost
# Port: 5432
# Database: postgres


# PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/mcms_db?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mcms_db
DB_USER=postgres
DB_PASSWORD=your_password_here

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret