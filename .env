# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  JSW MCMS — Root Environment Variables (Docker Compose)                ║
# ║  Copy to .env and fill in values. 


# Conneted to PostgreSQL PG Admin4
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/mcms_db?schema=public"


# Username: postgres
# Password: admin123
# Host: localhost
# Port: 5432
# Database: postgres


# PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/mcms_db?schema=public"

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mcms_db
DB_USER=postgres
DB_PASSWORD=your_password_here

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret



# ── PostgreSQL (local dev Docker) ─────────────────────────────────────────────
POSTGRES_PASSWORD=mcms_local_secret_change_me

# ── Backend API ───────────────────────────────────────────────────────────────
# For local: use docker db. For prod: use Neon connection string.
DATABASE_URL=postgresql://mcms:mcms_local_secret_change_me@db:5432/mcms?schema=public&sslmode=disable

# JWT Secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_TO_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_TO_LONG_RANDOM_REFRESH_SECRET

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# URL of deployed frontend (for CORS)
CLIENT_ORIGIN=http://localhost:5173

NODE_ENV=production
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API
VITE_API_URL=http://localhost:4000/api


Username: postgres
Password: admin123
Host: localhost
Port: 5432
Database: postgres